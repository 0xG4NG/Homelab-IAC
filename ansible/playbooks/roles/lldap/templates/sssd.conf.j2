# Managed by Ansible — do not edit manually

[sssd]
services = nss, pam, sudo
config_file_version = 2
domains = default

[nss]

[pam]

[sudo]

[domain/default]
id_provider = ldap
auth_provider = ldap

ldap_uri = {{ lldap_ldap_server }}
ldap_search_base = {{ lldap_ldap_basedn }}

{% if lldap_bind_dn %}
ldap_default_bind_dn = {{ lldap_bind_dn }}
ldap_default_authtok = {{ lldap_bind_password }}
{% endif %}

# LLDAP-specific schema settings
ldap_schema = rfc2307bis

ldap_user_search_base = ou=people,{{ lldap_ldap_basedn }}
ldap_user_object_class = person
ldap_user_name = uid
ldap_user_full_name = cn
ldap_user_home_directory = homeDirectory
ldap_user_gid_number = gidNumber

ldap_group_search_base = ou=groups,{{ lldap_ldap_basedn }}
ldap_group_object_class = groupOfNames
ldap_group_name = cn

ldap_sudo_search_base = ou=sudoers,{{ lldap_ldap_basedn }}

access_provider = ldap
cache_credentials = true
create_homedir = true
default_shell = {{ lldap_default_shell }}
fallback_homedir = {{ lldap_fallback_homedir }}
